{
  "name": "gallery-slideshow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "format": "prettier --write src/",
    "up": "docker compose up -d --build",
    "down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@chanzor/ts-leaf": "^1.1.2",
    "@chanzor/utils": "^0.2.2",
    "@chanzor/vue-utils": "^3.1.9",
    "@vueuse/core": "^10.11.1",
    "axios": "^1.15.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.8.1",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-inspect": "^11.3.3",
    "vue-tsc": "^3.2.6"
  }
}
